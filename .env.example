# ═══════════════════════════════════════════════════════════════
# NPC Contractual Engagement & Empanelment Portal
# Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ─── CORE [REQUIRED] ─────────────────────────────────────────
NODE_ENV=                          # [REQUIRED] production | development
PORT=3000                          # [OPTIONAL] Server port (default: 3000)

# ─── DATABASE [REQUIRED] ─────────────────────────────────────
DATABASE_URL=                      # [REQUIRED] PostgreSQL connection string
                                   # Example: postgresql://user:pass@host:5432/dbname

# ─── AUTHENTICATION [REQUIRED] ───────────────────────────────
TOKEN_SECRET=                      # [REQUIRED] HMAC signing key for auth tokens
                                   # Generate with: openssl rand -base64 64
                                   # MUST be unique, min 32 characters
NEXTAUTH_SECRET=                   # [OPTIONAL] Alias for TOKEN_SECRET (either works)
NEXTAUTH_URL=                      # [OPTIONAL] Base URL of the application

# ─── EMAIL (SMTP) [OPTIONAL] ─────────────────────────────────
SMTP_HOST=                         # [OPTIONAL] SMTP server hostname
SMTP_PORT=587                      # [OPTIONAL] SMTP port (default: 587)
SMTP_SECURE=false                  # [OPTIONAL] Use TLS (default: false)
SMTP_USER=                         # [OPTIONAL] SMTP username
SMTP_PASS=                         # [OPTIONAL] SMTP password
SMTP_FROM=noreply@npcindia.gov.in  # [OPTIONAL] From address

# ─── SMS [OPTIONAL] ──────────────────────────────────────────
SMS_PROVIDER=console               # [OPTIONAL] msg91 | nic_gateway | console
MSG91_AUTH_KEY=                     # [OPTIONAL] MSG91 authentication key
MSG91_SENDER_ID=NPCIND             # [OPTIONAL] MSG91 sender ID
MSG91_ROUTE=4                      # [OPTIONAL] MSG91 route (4=transactional)
NIC_SMS_API_URL=                   # [OPTIONAL] NIC SMS Gateway URL
NIC_SMS_USERNAME=                  # [OPTIONAL] NIC SMS username
NIC_SMS_PASSWORD=                  # [OPTIONAL] NIC SMS password
NIC_SMS_SENDER_ID=NPCIND           # [OPTIONAL] NIC SMS sender ID

# ─── FILE STORAGE [REQUIRED] ─────────────────────────────────
STORAGE_TYPE=local                 # [OPTIONAL] local | minio (default: local)
UPLOAD_DIR=./uploads               # [OPTIONAL] Local upload directory path

# ─── MINIO (when STORAGE_TYPE=minio) ─────────────────────────
MINIO_ENDPOINT=                    # [OPTIONAL] MinIO server hostname
MINIO_PORT=9000                    # [OPTIONAL] MinIO port
MINIO_USE_SSL=false                # [OPTIONAL] Use SSL for MinIO
MINIO_ACCESS_KEY=                  # [OPTIONAL] MinIO access key
MINIO_SECRET_KEY=                  # [OPTIONAL] MinIO secret key
MINIO_BUCKET=npc-portal            # [OPTIONAL] MinIO bucket name

# ─── REDIS (for caching/rate-limiting in production) ──────────
REDIS_URL=                         # [OPTIONAL] Redis connection string
                                   # Example: redis://localhost:6379

# ─── DEPLOYMENT ───────────────────────────────────────────────
APP_URL=                           # [OPTIONAL] Public-facing URL of the application
CORS_ORIGINS=                      # [OPTIONAL] Comma-separated allowed CORS origins
